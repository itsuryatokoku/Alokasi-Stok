  let masterData = [];

  // =========================
  // LOAD DATA
  // =========================

  async function loadData(){

    try{

      const response = await fetch(API_URL);

      masterData = await response.json();

      renderTable(masterData);

    }catch(error){

      console.error(error);

      document.getElementById("tableBody").innerHTML = `
        <tr>
          <td colspan="8" class="text-center text-danger">
            Gagal load data
          </td>
        </tr>
      `;

    }

  }

  // =========================
  // RENDER TABLE
  // =========================

  function renderTable(data){

    const tbody = document.getElementById("tableBody");

    tbody.innerHTML = "";

    if(data.length === 0){

      tbody.innerHTML = `
        <tr>
          <td colspan="8" class="text-center">
            Tidak ada data
          </td>
        </tr>
      `;

      return;

    }

    data.forEach(item => {

      tbody.innerHTML += `

        <tr>

          <td>${item.kodeItem ?? ""}</td>

          <td>${item.kodeOriginal ?? ""}</td>

          <td>${item.namaProduk ?? ""}</td>

          <td>${item.family ?? ""}</td>

          <td class="text-end">
            ${item.oh ?? 0}
          </td>

          <td class="text-end">
            ${item.stokGudang ?? 0}
          </td>

          <td class="text-end">
            ${item.standarStok ?? 0}
          </td>

          <td class="text-end alokasi">
            ${item.alokasiStok ?? 0}
          </td>

        </tr>

      `;

    });

  }

  // =========================
  // FILTER
  // =========================

  function filterData(){

    const brand =
      document.getElementById("brandInput")
      .value
      .toLowerCase();

    const stokFilter =
      document.getElementById("stokFilter")
      .value;

    let filtered = masterData.filter(item => {

      const family =
        (item.family || "")
        .toLowerCase();

      return family.includes(brand);

    });

    // FILTER STOK

    if(stokFilter === "TAKEN"){

      filtered = filtered.filter(
        item => Number(item.alokasiStok) > 0
      );

    }

    if(stokFilter === "ZERO"){

      filtered = filtered.filter(
        item => Number(item.stokGudang) <= 0
      );

    }

    if(stokFilter === "LOW"){

      filtered = filtered.filter(
        item => Number(item.stokGudang) > 0 &&
                Number(item.stokGudang) <= 10
      );

    }

    renderTable(filtered);

  }

  // =========================
  // EVENT
  // =========================

  document
    .getElementById("brandInput")
    .addEventListener("input", filterData);

  document
