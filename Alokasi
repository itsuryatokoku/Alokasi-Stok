    body{
      background:#f2f2f2;
      font-family:Arial, sans-serif;
      padding:10px;
    }

    .main-box{
      background:#fff;
      border-radius:20px;
      padding:20px;
      max-width:1400px;
      margin:auto;
      box-shadow:0 4px 10px rgba(0,0,0,0.1);
    }

    .title{
      text-align:center;
      font-size:70px;
      font-weight:300;
      margin-bottom:40px;
    }

    .form-section{
      max-width:700px;
      margin:auto;
      margin-bottom:30px;
    }

    .form-label{
      font-size:24px;
      font-weight:500;
      margin-bottom:8px;
    }

    .form-control,
    .form-select{
      height:50px;
      font-size:20px;
      border-radius:10px;
    }

    .table-wrapper{
      overflow-x:auto;
      border-radius:10px;
    }

    table{
      min-width:1000px;
      white-space:nowrap;
    }

    thead th{
      background:#f7f7f7 !important;
      position:sticky;
      top:0;
      z-index:2;
      text-align:center;
      vertical-align:middle;
    }

    td, th{
      font-size:14px;
      padding:8px !important;
    }

    .alokasi{
      background:#c8f1df !important;
      font-weight:bold;
    }

    .loading{
      text-align:center;
      padding:20px;
      font-size:18px;
    }

    @media(max-width:768px){

      .title{
        font-size:42px;
      }

      .form-label{
        font-size:18px;
      }

      .form-control,
      .form-select{
        font-size:16px;
        height:45px;
      }

      td, th{
        font-size:12px;
      }

    }

  </style>
</head>
<body>

<div class="main-box">

  <h1 class="title">Alokasi Stok</h1>

  <!-- FORM -->
  <div class="form-section">

    <!-- BRAND -->
    <div class="mb-3">

      <label class="form-label">Brand</label>

      <input
        type="text"
        id="brandInput"
        class="form-control"
        placeholder="Cari brand..."
      >

    </div>

    <!-- FILTER STOK -->
    <div class="mb-4">

      <label class="form-label">Tampilkan Stok</label>

      <select
        id="stokFilter"
        class="form-select"
      >
        <option value="ALL">All</option>
        <option value="TAKEN">Taken</option>
        <option value="ZERO">Zero</option>
        <option value="LOW">Low</option>
      </select>

    </div>

  </div>

  <!-- TABLE -->
  <div class="table-wrapper">

    <table class="table table-bordered table-hover align-middle">

      <thead>
        <tr>
          <th>Kode Item</th>
          <th>Kode Original</th>
          <th>Nama Produk</th>
          <th>Family</th>
          <th>OH</th>
          <th>Stok Gudang</th>
          <th>Standar Stok</th>
          <th>Alokasi Stok</th>
        </tr>
      </thead>

      <tbody id="tableBody">

        <tr>
          <td colspan="8" class="loading">
            Loading data...
          </td>
        </tr>

      </tbody>

    </table>

  </div>

</div>

